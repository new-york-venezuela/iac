# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
#
# Source before running Terraform:  source .env
# ============================================================

# ------------------------------------------------------------
# Hetzner Cloud
# ------------------------------------------------------------
# Generate at: https://console.hetzner.cloud → Project → API Tokens
export HCLOUD_TOKEN="your_hetzner_api_token_here"

# Automatically picks up HCLOUD_TOKEN; also exposed as TF_VAR
export TF_VAR_hcloud_token="${HCLOUD_TOKEN}"

# ------------------------------------------------------------
# Company / deployment identity  (replicate per client)
# ------------------------------------------------------------
export TF_VAR_company_name="acmecorp"           # Slug, no spaces
export TF_VAR_domain="acmecorp.com"
export TF_VAR_admin_email="admin@acmecorp.com"  # Used by Caddy for ACME

# ------------------------------------------------------------
# Infrastructure settings
# ------------------------------------------------------------
export TF_VAR_ssh_key_name="my-deploy-key"      # Must match key name in Hetzner console
export TF_VAR_server_location="fsn1"             # fsn1 | nbg1 | hel1 | ash | hil | sin
export TF_VAR_server_type="cx22"                 # cx22 = 2vCPU / 4 GB RAM
export TF_VAR_volume_size_gb="50"
export TF_VAR_timezone="Europe/Berlin"

# Optional: lock SSH to your office IP for production
# export TF_VAR_allowed_ssh_cidrs='["203.0.113.0/24"]'

# ------------------------------------------------------------
# Backblaze B2 offsite backups  (optional — set b2_enabled=true to activate)
# Generate application keys at: https://secure.backblaze.com/app_keys.htm
# Key needs: Read & Write on the target bucket (or all buckets for bucket creation)
# ------------------------------------------------------------
export B2_APPLICATION_KEY_ID="your_b2_key_id_here"
export B2_APPLICATION_KEY="your_b2_application_key_here"

# Terraform: create the B2 buckets and wire inventory
export TF_VAR_b2_enabled="false"                          # Set "true" to create buckets
export TF_VAR_b2_key_id="${B2_APPLICATION_KEY_ID}"
export TF_VAR_b2_application_key="${B2_APPLICATION_KEY}"
export TF_VAR_b2_bucket_name=""                           # Leave empty → mailcow-backup-{company_name}
                                                          # Must be globally unique across all B2 accounts
export TF_VAR_b2_tfstate_bucket_name=""                   # Leave empty → mailcow-tfstate-{company_name}
                                                          # Must be globally unique across all B2 accounts

# B2 S3-compatible API credentials for Terraform state backend
# Generate at: https://secure.backblaze.com/app_keys.htm
# Choose "Allowed capabilities: Read & Write" on the tfstate bucket
export AWS_ACCESS_KEY_ID="${B2_APPLICATION_KEY_ID}"
export AWS_SECRET_ACCESS_KEY="${B2_APPLICATION_KEY}"

# ------------------------------------------------------------
# Ansible extra-vars (passed with -e on ansible-playbook)
# These mirror Terraform vars so a single .env covers both.
# ------------------------------------------------------------
export ANSIBLE_DOMAIN="${TF_VAR_domain}"
export ANSIBLE_ADMIN_EMAIL="${TF_VAR_admin_email}"
export ANSIBLE_TIMEZONE="${TF_VAR_timezone}"
